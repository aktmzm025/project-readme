### 5-3. Node.js/Express — DB API 서버 라우터 분리

```javascript
// server.js (Port 3002)
const express = require('express');
const app = express();

app.use(express.json());

// 도메인별 라우터 분리
const userRouter    = require('./routes/userRoutes');
const gameRouter    = require('./routes/gameRoutes');
const rankingRouter = require('./routes/rankingRoutes');
const adminRouter   = require('./routes/adminRoutes');

app.use('/api/users',   userRouter);
app.use('/api/games',   gameRouter);
app.use('/api/ranking', rankingRouter);
app.use('/api/admin',   adminRouter);

app.listen(3002, () => {
    console.log('DB API Server running on port 3002');
});
```

```javascript
// routes/userRoutes.js
const express = require('express');
const router = express.Router();
const db = require('../db/connection');

// 회원 조회
router.get('/:id', async (req, res) => {
    try {
        const [rows] = await db.execute(
            'SELECT id, username, email, created_at FROM users WHERE id = ?',
            [req.params.id]
        );
        if (rows.length === 0) {
            return res.status(404).json({ message: '유저를 찾을 수 없습니다.' });
        }
        res.json(rows[0]);
    } catch (err) {
        res.status(500).json({ error: err.message });
    }
});

// 회원 등록
router.post('/register', async (req, res) => {
    const { username, email, password } = req.body;
    try {
        const [result] = await db.execute(
            'INSERT INTO users (username, email, password) VALUES (?, ?, ?)',
            [username, email, password]
        );
        res.json({ message: '회원가입 성공', userId: result.insertId });
    } catch (err) {
        res.status(500).json({ error: err.message });
    }
});

module.exports = router;
```

**설계 의도**: DB 관련 로직을 하나의 서버(3002)에 집중시키고, 도메인(users, games, ranking, admin)별로 라우터 파일을 분리함으로써 코드의 응집도를 높이고 각 도메인 수정 시 다른 도메인에 영향을 주지 않도록 설계했다.

